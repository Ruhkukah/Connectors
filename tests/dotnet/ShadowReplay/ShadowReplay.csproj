<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AlorEngineProject Condition="'$(AlorEngineProject)' == ''">$(ALORENGINE_PROJECT)</AlorEngineProject>
    <HasAlorEngineIntegration Condition="Exists('$(AlorEngineProject)')">true</HasAlorEngineIntegration>
    <DefineConstants Condition="'$(HasAlorEngineIntegration)' == 'true'">$(DefineConstants);ALORENGINE_INTEGRATION</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../../adapters/alorengine_dotnet/MoexConnector.AlorEngine.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(HasAlorEngineIntegration)' == 'true'">
    <ProjectReference Include="$(AlorEngineProject)" />
  </ItemGroup>
</Project>
